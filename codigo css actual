    .single-product .related .wd-entities-title,
    .single-product .up-sells .wd-entities-title,
    .single-product .cross-sells .wd-entities-title {
        font-size: 11px !important;
    }
    
    /* Desactivar animación shine de marcas en mobile */
    .woodmart-carousel-item::after,
    .brands-widget .wd-carousel-item::after,
    .wd-brands .wd-carousel-item::after {
        animation: none !important;
        display: none !important;
    }
    
    .woodmart-carousel-item img,
    .brands-widget img,
    .wd-brands img {
        filter: grayscale(30%) brightness(0.85) !important;
    }
    
    /* Header simplificado */
    .whb-main-header {
