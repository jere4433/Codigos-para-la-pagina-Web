/* ==========================================================================
   PARCHE COLIHUE AVENTURA v5 — FINAL
   
   Borrar CUALQUIER parche anterior. Pegar SOLO ESTE al final del CSS.
   
   Fix 1: Círculos marquee iOS + animaciones
   Fix 2: Botones carrito en carruseles — tamaño reducido
   Fix 3: Precio cortado en PC — más padding en tarjetas de carrusel
   Fix 4: Catálogo mobile — botón menos invasivo + menos naranja
   Fix 5: Relacionados mobile — botón que sobresale a la derecha
   Fix 6: Burbuja ChatBot.com — subir en mobile
   ========================================================================== */


/* ==========================================================================
   FIX 1: CÍRCULOS DEL MARQUEE — iOS Safari + animaciones
   ========================================================================== */

.pe-circle {
    -webkit-clip-path: circle(50% at 50% 50%);
    clip-path: circle(50% at 50% 50%);
    isolation: isolate;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
    overflow: hidden !important;
    -webkit-border-radius: 50%;
    border-radius: 50%;
}

.pe-circle img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: center center !important;
    display: block !important;
    border-radius: 0 !important;
    filter: none !important;
}

.pe-rifle-card .pe-circle {
    filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.8));
}

.pe-rifle-card:hover .pe-circle,
.pe-rifle-card:active .pe-circle {
    transform: scale(1.1) !important;
    border-color: var(--ca-blanco) !important;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 1), 0 0 25px rgba(255, 102, 0, 0.6) !important;
    filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.8));
}

.pe-rifle-card:hover .pe-circle img,
.pe-rifle-card:active .pe-circle img {
    transform: scale(1.15) rotate(3deg) !important;
}

.pe-rifle-card:hover .pe-rifle-name,
.pe-rifle-card:active .pe-rifle-name {
    color: var(--ca-naranja) !important;
}

@media (max-width: 768px) {
    .pe-circle {
        -webkit-clip-path: circle(50% at 50% 50%);
        clip-path: circle(50% at 50% 50%);
        -webkit-mask-image: radial-gradient(circle, #000 69%, transparent 70%);
        mask-image: radial-gradient(circle, #000 69%, transparent 70%);
    }
}


/* ==========================================================================
   FIX 2: BOTONES EN CARRUSELES — Tamaño reducido (desktop + mobile)
   ========================================================================== */

/* Carruseles home */
.wd-carousel .product-grid-item .add_to_cart_button,
.wd-carousel .product-grid-item .product_type_variable,
