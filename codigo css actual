    .wd-product:hover {
        transform: none !important;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4) !important;
    }
    
    .product-grid-item::before,
    .wd-product::before {
        display: none;
    }
    
    /* ===============================================
       CARRUSEL HOME MOBILE — Imágenes bien recortadas
       =============================================== */
    
    /* Solo para HOME - NO afectar single-product */
    body.home .wd-carousel .product-grid-item .product-image-link,
    body.home .wd-carousel .wd-product .product-image-link {
        overflow: hidden !important;
        border-radius: 8px !important;
    }
    
    body.home .wd-carousel .product-grid-item .product-image-link img,
    body.home .wd-carousel .wd-product .product-image-link img {
        width: 100% !important;
        height: auto !important;
        object-fit: cover !important;
        border-radius: 8px !important;
    }
    
    /* Precio en carrusel home mobile */
    body.home .wd-carousel .product-grid-item .price,
    body.home .wd-carousel .wd-product .price {
        font-size: 14px !important;
    }
    
    /* ===============================================
